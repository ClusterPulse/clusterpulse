{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "labels": ["dependencies"],
  "schedule": ["before 9am on friday"],
  "packageRules": [
    {
      "description": "Group Go toolchain updates (go.mod directive + Dockerfile base image)",
      "groupName": "Go toolchain",
      "matchDepNames": ["go", "golang"],
      "addLabels": ["go"]
    },
    {
      "description": "Group minor/patch Go dependency updates",
      "groupName": "Go dependencies (minor/patch)",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["minor", "patch"],
      "excludeDepNames": ["go"],
      "addLabels": ["go"]
    },
    {
      "description": "Group all GitHub Actions updates",
      "groupName": "GitHub Actions",
      "matchManagers": ["github-actions"],
      "addLabels": ["github-actions"]
    }
  ]
}
